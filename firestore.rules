rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CAMPUS HUB SECURITY RULES (PROTOTYPING MODE)
     * 
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict role-based and ownership-based authorization model while 
     * remaining flexible on data schema to support rapid iteration. It leverages denormalization 
     * and structural segregation to ensure performant and secure lookups.
     * 
     * DATA STRUCTURE:
     * - User profiles and private data (drafts, attempts) are stored under user-specific paths: /users/{userId}/...
     * - Publicly available content (published quizzes) is segregated into top-level collections: /quizzes_published/...
     * - Role markers exist at /roles_administrators/{userId} and /roles_students/{userId} for atomic exists() checks.
     * 
     * KEY SECURITY DECISIONS:
     * - Role-Based Access: Permissions often branch based on whether a user is an 'administrator' or 'student'.
     * - Authorization Independence: We favor denormalized ownership fields (e.g., quizAdminId) within documents 
     *   to avoid nested get() calls, especially for subcollections like Questions and AnswerOptions.
     * - Immutable Identity: Critical fields that link data to a specific user (like userId or studentId) 
     *   are validated on create and enforced as immutable on update.
     */

    // --- Helper Functions ---

    /** Checks if the requester is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the requester's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if a document exists and the requester is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the requester has the administrator role. */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrator';
    }

    /** Checks if the requester has the student role. */
    function isStudent() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     * @path /users/{userId}
     * @allow (create) if the user is creating their own profile.
     * @deny (list) for users who are not administrators.
     * @principle Private Data / Self-Creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Role marker for administrators.
     * @path /roles_administrators/{userId}
     * @allow (get) for signed in users to check roles.
     * @deny (write) for anyone except existing administrators.
     * @principle DBAC Markers.
     */
    match /roles_administrators/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Role marker for students.
     * @path /roles_students/{userId}
     * @allow (get) for signed in users to check roles.
     * @deny (write) for anyone except administrators.
     * @principle DBAC Markers.
     */
    match /roles_students/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Publicly available quizzes.
     * @path /quizzes_published/{quizId}
     * @allow (list) for all authenticated students.
     * @deny (update) if the user is not the owning admin or an admin.
     * @principle Structural Segregation / Public Read, Owner-Only Write.
     */
    match /quizzes_published/{quizId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.adminId == request.auth.uid;
      allow update, delete: if isAdmin() && (resource.data.adminId == request.auth.uid || isAdmin());
      
      /**
       * @description Questions belonging to a published quiz.
       * @path /quizzes_published/{quizId}/questions/{questionId}
       * @principle Authorization Independence via denormalized quizAdminId.
       */
      match /questions/{questionId} {
        allow get, list: if isSignedIn();
        allow create: if isAdmin() && request.resource.data.quizAdminId == request.auth.uid;
        allow update, delete: if isAdmin() && (resource.data.quizAdminId == request.auth.uid || isAdmin());

        /**
         * @description Answer options for published questions.
         * @path /quizzes_published/{quizId}/questions/{questionId}/answerOptions/{answerOptionId}
         */
        match /answerOptions/{answerOptionId} {
          allow get, list: if isSignedIn();
          allow create: if isAdmin() && request.resource.data.quizAdminId == request.auth.uid;
          allow update, delete: if isAdmin() && (resource.data.quizAdminId == request.auth.uid || isAdmin());
        }
      }
    }

    /**
     * @description Draft quizzes owned by a specific administrator.
     * @path /users/{adminId}/quizzes_drafts/{quizId}
     * @allow (get, list) for the creating administrator.
     * @deny (read) for students.
     * @principle User-Owned Data Trees.
     */
    match /users/{adminId}/quizzes_drafts/{quizId} {
      allow get, list: if isOwner(adminId) && isAdmin();
      allow create: if isOwner(adminId) && isAdmin() && request.resource.data.adminId == adminId;
      allow update: if isExistingOwner(adminId) && isAdmin() && request.resource.data.adminId == resource.data.adminId;
      allow delete: if isExistingOwner(adminId) && isAdmin();

      /**
       * @description Questions belonging to a draft quiz.
       */
      match /questions/{questionId} {
        allow get, list: if isOwner(adminId) && isAdmin();
        allow create, update, delete: if isOwner(adminId) && isAdmin();

        /**
         * @description Answer options for draft questions.
         */
        match /answerOptions/{answerOptionId} {
          allow get, list: if isOwner(adminId) && isAdmin();
          allow create, update, delete: if isOwner(adminId) && isAdmin();
        }
      }
    }

    /**
     * @description Student attempts for a quiz.
     * @path /users/{studentId}/quizAttempts/{quizAttemptId}
     * @allow (create) if the user matches the studentId.
     * @deny (read) for other students.
     * @principle Path-Based Ownership.
     */
    match /users/{studentId}/quizAttempts/{quizAttemptId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      // FIX: Utilize `isStudent()` to ensure only users with the 'student' role can create quiz attempts.
      allow create: if isOwner(studentId) && isStudent() && request.resource.data.studentId == studentId;
      allow update: if isExistingOwner(studentId) && request.resource.data.studentId == resource.data.studentId;
      allow delete: if isAdmin();

      /**
       * @description Answers provided by a student during a quiz attempt.
       * @path /users/{studentId}/quizAttempts/{quizAttemptId}/studentAnswers/{studentAnswerId}
       */
      match /studentAnswers/{studentAnswerId} {
        allow get, list: if isOwner(studentId) || isAdmin();
        allow create: if isOwner(studentId);
        allow update: if isExistingOwner(studentId);
        allow delete: if isAdmin();
      }
    }
  }
}